rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function tokenRole() {
      return isSignedIn() && 'role' in request.auth.token
        ? request.auth.token.role
        : null;
    }

    function docRole() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'USER';
    }

    // Prefer Firestore users/{uid}.role as source of truth (CMS may update
    // before custom claims refresh). Fall back to token claim, then USER.
    function role() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : (tokenRole() != null ? tokenRole() : 'USER');
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isClientOrAbove() {
      return role() in ['CLIENT', 'CLINICIAN', 'PUBLICIST', 'ADMIN'];
    }

    function isClinicianOrAbove() {
      return role() in ['CLINICIAN', 'PUBLICIST', 'ADMIN'];
    }

    function isPublicistOrAdmin() {
      return role() in ['PUBLICIST', 'ADMIN'];
    }

    function isAdmin() {
      return role() == 'ADMIN';
    }

    function memberRole(r) {
      return r in ['USER', 'CLIENT'];
    }

    function staffRole(r) {
      return r in ['CLINICIAN', 'PUBLICIST', 'ADMIN'];
    }

    function docRoleBefore() {
      return 'role' in resource.data ? resource.data.role : 'USER';
    }

    function docRoleAfter() {
      return 'role' in request.resource.data
        ? request.resource.data.role
        : docRoleBefore();
    }

    // Self may keep role, or move freely between USER and CLIENT only.
    // Never self-assign staff; never demote staff from the client.
    function selfRoleChangeAllowed() {
      let before = docRoleBefore();
      let after = docRoleAfter();
      return before == after
        || (memberRole(before) && memberRole(after));
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || isPublicistOrAdmin();

      // New accounts may start as USER or CLIENT (chat/SMS opt-in at signup)
      allow create: if isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.role in ['USER', 'CLIENT'];

      // Self: profile + preferences (chat/SMS/newsletter/phone) and USER↔CLIENT.
      // Admin: any update.
      allow update: if isAdmin()
        || (isSelf(uid) && selfRoleChangeAllowed() && !staffRole(docRoleAfter()));

      allow delete: if isSelf(uid) || isAdmin();
    }

    match /clinicians/{uid} {
      allow read: if true;
      allow write: if (isSelf(uid) && isClinicianOrAbove()) || isPublicistOrAdmin();
    }

    match /siteSettings/{docId} {
      allow read: if true;
      // Staff can toggle chat presence; Publicist+ can edit all site settings
      allow write: if isPublicistOrAdmin()
        || (docId == 'chatPresence' && isClinicianOrAbove());
    }

    match /quotes/{id} {
      allow read: if true;
      allow write: if isPublicistOrAdmin();
    }

    match /tools/{id} {
      allow read: if resource == null
        || resource.data.published == true
        || isPublicistOrAdmin();
      allow write: if isPublicistOrAdmin();
    }

    match /newsletters/{id} {
      // Members see published only (not draft/archived). Staff see all.
      allow read: if isPublicistOrAdmin()
        || (isSignedIn() && resource.data.status == 'published');
      allow create, update: if isPublicistOrAdmin();
      // Delete: draft or unsent published (PUBLICIST+); archived only ADMIN.
      // Blasted (sentAt set) published issues cannot be deleted — archive instead.
      allow delete: if isPublicistOrAdmin()
        && (
          resource.data.status == 'draft'
          || (
            resource.data.status == 'published'
            && !('sentAt' in resource.data)
          )
          || (
            resource.data.status == 'archived'
            && isAdmin()
          )
        );
    }

    match /contactMessages/{id} {
      allow create: if true;
      allow read, update, delete: if isPublicistOrAdmin();
    }

    match /chats/{chatId} {
      allow read: if isSignedIn()
        && (resource.data.clientUid == request.auth.uid
          || isClinicianOrAbove());
      // Clients open their own threads; staff may also open for testing (CLINICIAN+)
      allow create: if isSignedIn()
        && request.resource.data.clientUid == request.auth.uid
        && (
          isClientOrAbove()
          || isClinicianOrAbove()
        )
        && request.resource.data.status in ['queued', 'active'];
      // Staff claim/close; client may close own chat
      allow update: if isClinicianOrAbove()
        || (isSignedIn()
          && resource.data.clientUid == request.auth.uid
          && request.resource.data.clientUid == resource.data.clientUid);

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && (get(/databases/$(database)/documents/chats/$(chatId)).data.clientUid
                == request.auth.uid
            || isClinicianOrAbove());
        allow create: if isSignedIn()
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.keys().hasAll(['senderUid', 'text', 'senderKind'])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && (get(/databases/$(database)/documents/chats/$(chatId)).data.clientUid
                == request.auth.uid
            || isClinicianOrAbove());
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
