rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function tokenRole() {
      return isSignedIn() && 'role' in request.auth.token
        ? request.auth.token.role
        : null;
    }

    function docRole() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'USER';
    }

    function role() {
      return tokenRole() != null ? tokenRole() : docRole();
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isClientOrAbove() {
      return role() in ['CLIENT', 'CLINICIAN', 'PUBLICIST', 'ADMIN'];
    }

    function isClinicianOrAbove() {
      return role() in ['CLINICIAN', 'PUBLICIST', 'ADMIN'];
    }

    function isPublicistOrAdmin() {
      return role() in ['PUBLICIST', 'ADMIN'];
    }

    function isAdmin() {
      return role() == 'ADMIN';
    }

    function memberRole(r) {
      return r in ['USER', 'CLIENT'];
    }

    function staffRole(r) {
      return r in ['CLINICIAN', 'PUBLICIST', 'ADMIN'];
    }

    function docRoleBefore() {
      return 'role' in resource.data ? resource.data.role : 'USER';
    }

    function docRoleAfter() {
      return 'role' in request.resource.data
        ? request.resource.data.role
        : docRoleBefore();
    }

    // Self may keep role, or move freely between USER and CLIENT only.
    // Never self-assign staff; never demote staff from the client.
    function selfRoleChangeAllowed() {
      let before = docRoleBefore();
      let after = docRoleAfter();
      return before == after
        || (memberRole(before) && memberRole(after));
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || isPublicistOrAdmin();

      // New accounts may start as USER or CLIENT (chat/SMS opt-in at signup)
      allow create: if isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.role in ['USER', 'CLIENT'];

      // Self: profile + preferences (chat/SMS/newsletter/phone) and USER↔CLIENT.
      // Admin: any update.
      allow update: if isAdmin()
        || (isSelf(uid) && selfRoleChangeAllowed() && !staffRole(docRoleAfter()));

      allow delete: if isSelf(uid) || isAdmin();
    }

    match /clinicians/{uid} {
      allow read: if true;
      allow write: if (isSelf(uid) && isClinicianOrAbove()) || isPublicistOrAdmin();
    }

    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if isPublicistOrAdmin();
    }

    match /quotes/{id} {
      allow read: if true;
      allow write: if isPublicistOrAdmin();
    }

    match /tools/{id} {
      allow read: if resource == null
        || resource.data.published == true
        || isPublicistOrAdmin();
      allow write: if isPublicistOrAdmin();
    }

    match /newsletters/{id} {
      allow read: if isPublicistOrAdmin()
        || (isSignedIn() && resource.data.status == 'published');
      allow write: if isPublicistOrAdmin();
    }

    match /contactMessages/{id} {
      allow create: if true;
      allow read, update, delete: if isPublicistOrAdmin();
    }

    match /chats/{chatId} {
      allow read: if isSignedIn()
        && (resource.data.clientUid == request.auth.uid
          || isClinicianOrAbove());
      allow create: if isClientOrAbove()
        && request.resource.data.clientUid == request.auth.uid;
      allow update: if isClinicianOrAbove()
        || (isClientOrAbove() && resource.data.clientUid == request.auth.uid);

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && (get(/databases/$(database)/documents/chats/$(chatId)).data.clientUid
                == request.auth.uid
            || isClinicianOrAbove());
        allow create: if isSignedIn()
          && request.resource.data.senderUid == request.auth.uid
          && (get(/databases/$(database)/documents/chats/$(chatId)).data.clientUid
                == request.auth.uid
            || isClinicianOrAbove());
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
